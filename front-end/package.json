{
  "private": true,
  "scripts": {
    "build": "tsc && vite build",
    "coverage": "vitest run --coverage",
    "dev": "vite",
    "prisma:migrate:up": "prisma migrate deploy",
    "prisma:studio": "npx prisma studio",
    "start": "node ../server/server.js",
    "test": "npm run test:unit && npm run test:browser",
    "test:browser": "vitest run --project browser",
    "test:browser:watch": "vitest watch --project browser --browser.headless=false --test-timeout=1000",
    "test:unit": "vitest run --project unit",
    "test:unit:watch": "vitest watch --project unit",
    "tokens": "node scripts/build-tokens.js",
    "watch": "node --watch ../server/server.js"
  },
  "type": "module",
  "dependencies": {
    "@prisma/client": "7.7.0"
  },
  "devDependencies": {
    "@lit-labs/signals": "0.2.0",
    "@types/canvas-confetti": "1.9.0",
    "@vitest/browser-playwright": "4.1.4",
    "canvas-confetti": "1.9.4",
    "chart.js": "4.5.1",
    "jsdom": "29.0.1",
    "lit": "3.3.2",
    "style-dictionary": "5.4.0",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vitest": "4.1.4",
    "vitest-browser-lit": "1.0.1"
  }
}
