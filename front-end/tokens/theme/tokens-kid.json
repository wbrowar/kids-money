{
  "kid": {
    "color": {
      "$type": "color",
      "bg": {
        "light": {
          "$value": "color-mix({color.favorite} 10%, light-dark(rgb(255 255 255), rgb(40 40 40)))"
        },
        "gradient": {
          "$value": "linear-gradient(color-mix({kid.color.bg.light} 90%, {color.favorite}), {kid.color.bg.light})"
        }
      },
      "border": {
        "$value": "color-mix({color.favorite} 40%, transparent)"
      },
      "favorite": {
        "$value": "{color.favorite}"
      },
      "text": {
        "on-favorite": {
          "$value": "color-mix({color.favorite} 16%, contrast-color({color.favorite}))"
        },
        "on-bg-light": {
          "$value": "color-mix({color.favorite} 16%, contrast-color({kid.color.bg.light}))"
        }
      }
    },
    "box-shadow": {
      "card": {
        "$value": "0 10px 20px color-mix({color.favorite} 50%, transparent), 0 5px 10px color-mix({color.favorite} 50%, transparent)"
      },
      "element": {
        "$value": "0 5px 24px color-mix({color.favorite} 10%, transparent), 0 4px 5px color-mix({color.favorite} 40%, transparent)"
      }
    }
  }
}
